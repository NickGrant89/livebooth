# HTTPS in front of MediaMTX HLS (required — browsers block http:// HLS on https:// LiveBooth)
#
# Install Caddy on the VPS, then:
#   sudo cp Caddyfile.example /etc/caddy/Caddyfile
#   # edit domains + email
#   sudo systemctl reload caddy
#
# DNS: hls.yourdomain.com → VPS public IP

{
	email you@yourdomain.com
}

# HLS playback (fans watch in browser) + archive recordings at /recordings/
hls.livebooth.uk {
	handle /recordings/* {
		uri strip_prefix /recordings
		root * /opt/livebooth/rtmp-server/recordings
		file_server browse
		header Access-Control-Allow-Origin *
	}
	reverse_proxy 127.0.0.1:8888
}

# Optional separate subdomain (requires DNS A record → VPS IP):
# stream.livebooth.uk {
# 	root * /opt/livebooth/rtmp-server/recordings
# 	file_server browse
# 	header Access-Control-Allow-Origin *
# }

# RTMP ingest stays on port 1935 (OBS) — no Caddy needed for rtmp://
