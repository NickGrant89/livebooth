{
  "name": "livebooth",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3008",
    "dev:clean": "lsof -ti :3008 | xargs kill -9 2>/dev/null; next dev -p 3008",
    "demo:setup": "npx tsx scripts/demo-setup.ts",
    "demo:start": "npm run demo:ensure-db && lsof -ti :3008 | xargs kill -9 2>/dev/null; next dev -H 0.0.0.0 -p 3008",
    "demo:ensure-db": "npx tsx scripts/ensure-demo-db.ts",
    "demo:fresh": "npm run demo:setup && npm run demo:start",
    "rtmp:start": "docker compose -f rtmp-server/docker-compose.yml up -d",
    "rtmp:stop": "docker compose -f rtmp-server/docker-compose.yml down",
    "rtmp:logs": "docker compose -f rtmp-server/docker-compose.yml logs -f",
    "rtmp:status": "curl -s http://127.0.0.1:9997/v3/paths/list | head -c 2000",
    "contracts:compile": "cd contracts && npm run compile",
    "contracts:test": "cd contracts && npm test",
    "contracts:deploy": "cd contracts && npm run deploy:vechain",
    "contracts:deploy:local": "cd contracts && npm run deploy:local",
    "contracts:rpc-proxy": "cd contracts && npx @vechain/sdk-rpc-proxy -u https://testnet.vechain.org -p 8545",
    "contracts:env": "npx tsx scripts/print-deploy-env.ts",
    "contracts:sync-env": "npx tsx scripts/sync-contract-env.ts",
    "contracts:verify": "npx tsx scripts/verify-testnet.ts",
    "smoke:withdrawal": "npx tsx scripts/smoke-withdrawal.ts",
    "smoke:onchain": "npx tsx scripts/smoke-onchain.ts",
    "smoke:deploy": "npx tsx scripts/smoke-deploy.ts",
    "launch:check": "npx tsx scripts/launch-check.ts",
    "admin:promote": "npx tsx scripts/promote-admin.ts",
    "build": "prisma generate && next build",
    "vercel-build": "prisma generate && npx tsx scripts/migrate-deploy.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:wait": "npx tsx scripts/wait-for-postgres.ts",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "npx tsx scripts/migrate-deploy.ts",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed:demo": "SEED_DEMO_USERS=true npx tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:postgres:setup": "npm run db:up && npm run db:wait && npm run db:migrate:deploy",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.1075.0",
    "@chakra-ui/react": "^2.10.10",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@livekit/components-react": "^2.9.21",
    "@livekit/components-styles": "^1.2.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.101.2",
    "@vechain/dapp-kit": "^2.3.2",
    "@vechain/dapp-kit-react": "^2.3.2",
    "@vechain/vechain-kit": "^2.12.0",
    "@vechain/web3-providers-connex": "^1.1.2",
    "@wagmi/core": "2.22.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.42.2",
    "hls.js": "^1.6.16",
    "jose": "^6.2.3",
    "livekit-client": "^2.20.0",
    "livekit-server-sdk": "^2.16.0",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "otplib": "^13.4.1",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "stripe": "^22.3.0",
    "tsx": "^4.22.4",
    "viem": "2.47.12",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "overrides": {
    "use-sync-external-store": "^1.6.0",
    "viem": "2.47.12",
    "@wagmi/core": "2.22.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
